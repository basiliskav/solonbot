# Copy this file to .env and change values to override.

# Timezone for all containers. Affects log timestamps, cron scheduling, etc.
# Examples: America/New_York, Europe/London, Asia/Tokyo
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Postgres credentials. Passed to both the postgres and app containers.
POSTGRES_USER=solonbot
POSTGRES_PASSWORD=solonbot
POSTGRES_DB=solonbot

# Uncomment to enable optional services. Multiple profiles are comma-separated.
# Available profiles: signal (Signal bridge), coder (Claude Code agent).
#COMPOSE_PROFILES=signal,coder
